# Host port mappings
FRONTEND_PORT=80
FASTAPI_PORT=8000
SPRING_PORT=8080

# Shared CORS policy used by both backend services
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

# FastAPI tuning
INFERENCE_CACHE_SIZE=512

# Spring + Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_RESULTS_TABLE=prediction_results
SUPABASE_RISK_SETTINGS_TABLE=risk_classification_settings
AUTH_COOKIE_NAME=cb_auth_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
